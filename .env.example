# ============================================================
# HAMA LMS — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── App ─────────────────────────────────────────────────────
VITE_SITE_URL=https://your-domain.com

# ── Payment ─────────────────────────────────────────────────
VITE_PAYSTACK_PUBLIC_KEY=pk_test_...
# Set in Supabase Edge Functions secrets (NOT in frontend env file):
# PAYSTACK_SECRET_KEY=sk_test_...
#
# Live mode switch:
# - Replace VITE_PAYSTACK_PUBLIC_KEY with pk_live_...
# - Replace PAYSTACK_SECRET_KEY in Supabase secrets with sk_live_...

# ── AI ──────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=your-gemini-api-key

# --- Certificate PDF Generation ---
#
# Certificates are now generated using pdf-lib in the generate-certificate edge function.
# No additional secrets are required for basic PDF generation.
#
# The system uses a clean template-based approach:
#   - PDF is generated server-side using pdf-lib
#   - Uploaded to Supabase Storage bucket "certificates"
#   - No external services (browserless/puppeteer) required
#
# ── Supabase Storage Bucket ──────────────────────────────────
# Ensure a public storage bucket named "certificates" exists in your Supabase project.
# Dashboard → Storage → New Bucket → Name: certificates → Public: true
# No additional .env variable needed — the bucket name is hardcoded in the edge functions.
