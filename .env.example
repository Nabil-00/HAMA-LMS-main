# ============================================================
# HAMA LMS — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── App ─────────────────────────────────────────────────────
VITE_SITE_URL=https://your-domain.com

# ── Payment ─────────────────────────────────────────────────
VITE_PAYSTACK_PUBLIC_KEY=pk_test_...

# ── AI ──────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=your-gemini-api-key

# ── Certificate PDF Generation (Supabase Secrets — NOT .env) ─
#
# These are used server-side ONLY in the Supabase Edge Functions.
# Set them via the Supabase CLI, NOT in this file:
#
#   supabase secrets set BROWSER_WS_ENDPOINT=wss://...
#   supabase secrets set INTERNAL_SECRET=<random-string>
#
# BROWSER_WS_ENDPOINT
#   WebSocket URL of a remote headless Chrome instance used by the
#   render-certificate-pdf edge function to generate PDFs.
#
#   Options:
#     • Browserless.io (managed, free tier available):
#         wss://chrome.browserless.io?token=YOUR_API_TOKEN
#         Sign up at https://www.browserless.io/
#
#     • Self-hosted on a VPS (run once):
#         chromium --headless=new --remote-debugging-port=9222 --no-sandbox
#         Then expose port 9222 and use: ws://YOUR_VPS_IP:9222
#
#     • Docker (Railway / Render / Fly.io):
#         Deploy the ghcr.io/browserless/chromium image and use its WebSocket URL.
#
# INTERNAL_SECRET
#   A random secret string shared between generate-certificate and
#   render-certificate-pdf to prevent the PDF function from being called publicly.
#   Generate with: openssl rand -hex 32
#
# ── Supabase Storage Bucket ──────────────────────────────────
# Ensure a public storage bucket named "certificates" exists in your Supabase project.
# Dashboard → Storage → New Bucket → Name: certificates → Public: true
# No additional .env variable needed — the bucket name is hardcoded in the edge functions.
